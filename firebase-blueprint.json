{
  "entities": {
    "InfographicState": {
      "title": "Infographic State",
      "description": "State containing all infographics data for Kesyahbandaran",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "goals": { "type": "string" }
      }
    },
    "PortsState": {
      "title": "Ports State",
      "description": "The complete list of interactive ports on the map",
      "type": "object",
      "properties": {
        "list": { "type": "array" }
      }
    }
  },
  "firestore": {
    "/infographics/{id}": {
      "schema": "InfographicState",
      "description": "Global settings and infographics state"
    },
    "/ports/{id}": {
      "schema": "PortsState",
      "description": "Interactive ports database state"
    }
  }
}
